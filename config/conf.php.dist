// ----------------------------------------------------------------------
// CalDAV Driver Settings
// ----------------------------------------------------------------------

// What CalDAV storage driver should we use?
// Options:
//   'sql' - SQL
//   'null' - Do not save extra attributes
$conf['caldav']['driver'] = 'sql';

