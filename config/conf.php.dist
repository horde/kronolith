// ----------------------------------------------------------------------
// Resource Settings
// ----------------------------------------------------------------------

// Should resource scheduling be enabled?
$conf['resources']['enabled'] = true;


// ----------------------------------------------------------------------
// Reminder Settings
// ----------------------------------------------------------------------

// Server name from which reminder    emails should be sent
$conf['reminder']['server_name'] = '';

// Email address from which reminder    emails should be sent
$conf['reminder']['from_addr'] = '';


// ----------------------------------------------------------------------
// Share Settings
// ----------------------------------------------------------------------


// Notify users and groups per e-mail if   they have been granted access to a shared calendar (or tasklist), or are the   new owner of the share?
$conf['share']['notify'] = false;


// ----------------------------------------------------------------------
// Displaying Holidays
// ----------------------------------------------------------------------

// Should support for holidays be enabled?
$conf['holidays']['enable'] = true;


// ----------------------------------------------------------------------
// Menu Settings
// ----------------------------------------------------------------------

// Should we display an Import/Export    link in the Horde application menus?
$conf['menu']['import_export'] = true;


